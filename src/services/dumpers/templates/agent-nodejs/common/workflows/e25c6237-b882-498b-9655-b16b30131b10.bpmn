<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:forest="https://app.forestadmin.com" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_0hdve55" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.6.1"><bpmn:process id="Process_1s8zutc" isExecutable="false"><bpmn:startEvent id="StartEvent_0b1zhsz" name="Start of workflow"><bpmn:outgoing>Flow__8v0wyut</bpmn:outgoing></bpmn:startEvent><bpmn:SequenceFlow id="Flow__8v0wyut" sourceRef="StartEvent_0b1zhsz" targetRef="Activity__5ezjc9p" /><bpmn:ServiceTask id="Activity__5ezjc9p" name="Retrieve data from Forest" forest:description="🔎 First, let&#39;s load some data available in Forest regarding the selected document:&#10;- document type&#10;- URL&#10;- uploaded date" forest:alternative="get-data" forest:automaticCompletion="true"><bpmn:incoming>Flow__8v0wyut</bpmn:incoming><bpmn:outgoing>Flow__ya2guwx</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__ya2guwx" sourceRef="Activity__5ezjc9p" targetRef="Activity__hhyjybz" /><bpmn:ServiceTask id="Activity__hhyjybz" name="Extract document info" forest:description="🪪 Now, let&#39;s extract information from the document, using the Mistral OCR.&#10;&#10;Click on Done once it&#39;s been executed to move on to the next step." forest:alternative="mcp-server" forest:mcpServerId="128" forest:automaticExecution="true" forest:automaticCompletion="false"><bpmn:incoming>Flow__ya2guwx</bpmn:incoming><bpmn:outgoing>Flow__1b0bvhk</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__1b0bvhk" sourceRef="Activity__hhyjybz" targetRef="Activity__sh0g3gf" /><bpmn:ServiceTask id="Activity__sh0g3gf" name="Verify Document" forest:description="⚡️ Now let&#39;s trigger the Verify Document action. It&#39;s got some logic in it to review the submitted document and either verify or reject it.&#10;&#10;Click on Execute to execute the action." forest:alternative="trigger-action" forest:automaticCompletion="true"><bpmn:incoming>Flow__1b0bvhk</bpmn:incoming><bpmn:outgoing>Flow__hryop7e</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__hryop7e" sourceRef="Activity__sh0g3gf" targetRef="Activity__4cvvcha" /><bpmn:endEvent id="Activity__zdd5gmm" name="Document verified successfully!" forest:description="🎉 Congrats, the document was verified successfully!&#10;&#10;🙅 You may now close this workflow."><bpmn:incoming>Flow__f0l189z</bpmn:incoming></bpmn:endEvent><bpmn:ExclusiveGateway id="Gateway__9iy7l5c" name="Document verified?" forest:description="🧐 Was the document verified successfully?" forest:aiDecision="false"><bpmn:incoming>Flow__4mkf9m7</bpmn:incoming><bpmn:outgoing>Flow__f0l189z</bpmn:outgoing><bpmn:outgoing>Flow__3709hx6</bpmn:outgoing></bpmn:ExclusiveGateway><bpmn:SequenceFlow id="Flow__f0l189z" name="Yes, verified" sourceRef="Gateway__9iy7l5c" targetRef="Activity__zdd5gmm" /><bpmn:SequenceFlow id="Flow__3709hx6" name="Not verified" sourceRef="Gateway__9iy7l5c" targetRef="Activity__8gginj5" forest:buttonColor="red" /><bpmn:ServiceTask id="Activity__4cvvcha" name="Check document&#39;s verification status" forest:description="👀 Now let&#39;s double check that the data was updated accordingly, by checking the value of the document&#39;s Verified field." forest:alternative="get-data" forest:automaticCompletion="false"><bpmn:incoming>Flow__hryop7e</bpmn:incoming><bpmn:outgoing>Flow__4mkf9m7</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__4mkf9m7" sourceRef="Activity__4cvvcha" targetRef="Gateway__9iy7l5c" /><bpmn:endEvent id="Activity__8gginj5" name="Document not verified!" forest:description="❌ The document could not be verified - this is the end of the workflow, but at this point the next step would probably be to contact the Customer and ask them to upload a valid version of this document.&#10;&#10;🙅 For the time being, you may now close this workflow."><bpmn:incoming>Flow__3709hx6</bpmn:incoming></bpmn:endEvent></bpmn:process><bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1s8zutc"><bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_0b1zhsz"><dc:Bounds x="182" y="352" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="159" y="395" width="82" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_0qk9ox7_di" bpmnElement="Activity__5ezjc9p"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_07wi4uh_di" bpmnElement="Activity__hhyjybz"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_067m19p_di" bpmnElement="Activity__sh0g3gf"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_0rto1sl_di" bpmnElement="Activity__zdd5gmm"><dc:Bounds x="50" y="60" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="27" y="103" width="89" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Gateway__9iy7l5c_di" bpmnElement="Gateway__9iy7l5c" isMarkerVisible="true"><dc:Bounds x="75" y="75" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="78" y="132" width="51" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity__4cvvcha_di" bpmnElement="Activity__4cvvcha"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_1snse6c_di" bpmnElement="Activity__8gginj5"><dc:Bounds x="50" y="60" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="39" y="103" width="69" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNEdge id="Flow__8v0wyut_di" bpmnElement="Flow__8v0wyut"><di:waypoint x="182" y="370" /><di:waypoint x="1