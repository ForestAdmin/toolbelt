<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:forest="https://app.forestadmin.com" id="Definitions_0hdve55" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.6.1"><bpmn:process id="Process_1s8zutc" isExecutable="false"><bpmn:startEvent id="StartEvent_0b1zhsz" name="Start of workflow"><bpmn:outgoing>Flow__lqj4e1q</bpmn:outgoing></bpmn:startEvent><bpmn:SequenceFlow id="Flow__lqj4e1q" sourceRef="StartEvent_0b1zhsz" targetRef="Activity__7ao8ulm" /><bpmn:UserTask id="Activity__7ao8ulm" name="Before you start" forest:description="👋 Welcome to the Customer Onboarding workflow!&#10;&#10;✅ This will act as a checklist, taking you through a (very) simple onboarding process, in a few easy steps.&#10;&#10;🌲 Forest will help you retrieve data necessary for the onboarding, make easy Decisions using AI, and let you trigger Actions, in this case to either approve/reject a customer&#39;s onboarding, or Escalate the case to a Lvl2 agent.&#10;&#10;👇 Click here to get started!"><bpmn:incoming>Flow__lqj4e1q</bpmn:incoming><bpmn:outgoing>Flow__qhqypbu</bpmn:outgoing></bpmn:UserTask><bpmn:SequenceFlow id="Flow__qhqypbu" name="Let&#39;s go!" sourceRef="Activity__7ao8ulm" targetRef="Activity__ebutdlx" /><bpmn:ServiceTask id="Activity__jy63n9z" name="Retrieve customer&#39;s data" forest:description="Now, our AI will retrieve some of the customer&#39;s data needed to check whether we should approve, reject, or escalate their onboarding request.&#10;&#10;We need the following information:&#10;- First and last name&#10;- Date of birth&#10;- Country&#10;- Risk score" forest:alternative="get-data" forest:automaticCompletion="true"><bpmn:incoming>Flow__z9sgzu6</bpmn:incoming><bpmn:outgoing>Flow__g2dfmm5</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__g2dfmm5" sourceRef="Activity__jy63n9z" targetRef="Activity__57hu482" /><bpmn:ExclusiveGateway id="Activity__md177lq" name="Safe to onboard?" forest:description="👀 Based on the customer&#39;s Risk Score, should we onboard this customer?&#10;&#10;If the risk is Low, onboard them.&#10;If it&#39;s High, reject them.&#10;Otherwise, let&#39;s escalate to a Lvl2." forest:aiDecision="true"><bpmn:incoming>Flow__0v4baj3</bpmn:incoming><bpmn:outgoing>Flow__pvkegu2</bpmn:outgoing><bpmn:outgoing>Flow__q9knbpb</bpmn:outgoing><bpmn:outgoing>Flow__ocsyn4f</bpmn:outgoing></bpmn:ExclusiveGateway><bpmn:SequenceFlow id="Flow__pvkegu2" name="Yes, approve them" sourceRef="Activity__md177lq" targetRef="Activity__kv2b8cd" /><bpmn:SequenceFlow id="Flow__q9knbpb" name="In doubt, escalate" sourceRef="Activity__md177lq" targetRef="Activity__mm99xbj" forest:buttonColor="yellow" /><bpmn:SequenceFlow id="Flow__ocsyn4f" name="Nope, reject them" sourceRef="Activity__md177lq" targetRef="Activity__c737oxi" forest:buttonColor="red" /><bpmn:UserTask id="Activity__57hu482" name="Let&#39;s skip a few steps..." forest:description="🪪 In a real world scenario, you&#39;d cross reference that information with a document, such as a proof of ID and/or a proof of address.&#10;&#10;📑 You may also want to query official registries to get more in-depth information on this customer; are they politically exposed (PEP), do they have a history sanctions, or adverse media?&#10;&#10;You can do all this by loading more data from Forest, or plugging in 3rd party vendors and agents right into this workflow.&#10;&#10;In our simplified case, we&#39;ll just use the Risk Score retrieved previously to make that call - and we&#39;ll let our AI take care of that Decision for us, to guide us down the relevant branch."><bpmn:incoming>Flow__g2dfmm5</bpmn:incoming><bpmn:outgoing>Flow__0v4baj3</bpmn:outgoing></bpmn:UserTask><bpmn:SequenceFlow id="Flow__0v4baj3" name="Got it!" sourceRef="Activity__57hu482" targetRef="Activity__md177lq" /><bpmn:ServiceTask id="Activity__kv2b8cd" name="Approve onboarding" forest:description="🙌 Alright, then let&#39;s trigger the Approve Onboarding action on the KYC Case, so we can get the customer fully signed up!&#10;&#10;👇 Click on Execute below to trigger the Action and onboard the customer." forest:alternative="trigger-action" forest:automaticCompletion="true"><bpmn:incoming>Flow__pvkegu2</bpmn:incoming><bpmn:incoming>Flow__3d4ngu8</bpmn:incoming><bpmn:outgoing>Flow__szxp4t6</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__szxp4t6" sourceRef="Activity__kv2b8cd" targetRef="Activity__hb589f3" /><bpmn:ServiceTask id="Activity__ebutdlx" name="Load Customer" forest:description=" First, we need to load the Customer related to this KYC Case.&#10;&#10;In the Customer collection, select the relevant record, and click on &#34;Use this record&#34;.&#10;&#10;🪄 The purple box will appear whenever our AI can help you execute a step." forest:alternative="load-related-record" forest:automaticCompletion="true"><bpmn:incoming>Flow__qhqypbu</bpmn:incoming><bpmn:outgoing>Flow__z9sgzu6</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__z9sgzu6" sourceRef="Activity__ebutdlx" targetRef="Activity__jy63n9z" /><bpmn:endEvent id="Activity__tbiqcgu" name="Customer rejected" forest:description="🥲 Alright, you&#39;ve successfully rejected this customer&#39;s sign up.&#10;&#10;➡️ You may now close this workflow, and maybe move on to the next KYC Case if you want to Escalate or Approve the next one."><bpmn:incoming>Flow__hc5hhja</bpmn:incoming></bpmn:endEvent><bpmn:ServiceTask id="Activity__c737oxi" name="Reject onboarding" forest:description="😔 Alright, then let&#39;s trigger the Reject Onboarding action on the KYC Case.&#10;&#10;👇 Click on Execute below to trigger the Action and reject their application." forest:alternative="trigger-action" forest:automaticCompletion="true"><bpmn:incoming>Flow__ocsyn4f</bpmn:incoming><bpmn:incoming>Flow__1d0u9zt</bpmn:incoming><bpmn:outgoing>Flow__hc5hhja</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__hc5hhja" sourceRef="Activity__c737oxi" targetRef="Activity__tbiqcgu" /><bpmn:endEvent id="Activity__hb589f3" name="Customer onboarded" forest:description="🎉 Congrats, you&#39;ve successfully onboarded this customer!&#10;&#10;➡️ You may now close this workflow, and maybe move on to the next KYC Case if you want to Escalate or Reject the next one."><bpmn:incoming>Flow__szxp4t6</bpmn:incoming></bpmn:endEvent><bpmn:IntermediateThrowEvent id="Activity__mm99xbj" name="Escalation" forest:inboxId="a2d69bb7-fb5b-4fd5-b8d1-5b0727bab91d"><bpmn:incoming>Flow__q9knbpb</bpmn:incoming><bpmn:outgoing>Flow__wz290pt</bpmn:outgoing></bpmn:IntermediateThrowEvent><bpmn:SequenceFlow id="Flow__wz290pt" sourceRef="Activity__mm99xbj" targetRef="Gateway__3joix88" /><bpmn:ExclusiveGateway id="Gateway__3joix88" name="Lvl2 - Safe to onboard?" forest:description="👋 Hi Lvl2 agent, thanks for taking over!&#10;&#10;🧐 This KYC Case was escalated, as the Lvl1 agent didn&#39;t have the necessary information to make the decision as to whether this customer should be onboarded or not.&#10;&#10;👀 So the Decision is yours now - should we approve or reject this customer&#39;s sign-up?"><bpmn:incoming>Flow__wz290pt</bpmn:incoming><bpmn:outgoing>Flow__3d4ngu8</bpmn:outgoing><bpmn:outgoing>Flow__1d0u9zt</bpmn:outgoing></bpmn:ExclusiveGateway><bpmn:SequenceFlow id="Flow__3d4ngu8" name="Approve" sourceRef="Gateway__3joix88" targetRef="Activity__kv2b8cd" forest:isLinkTo="true" /><bpmn:SequenceFlow id="Flow__1d0u9zt" name="Reject" sourceRef="Gateway__3joix88" targetRef="Activity__c737oxi" forest:buttonColor="red" forest:isLinkTo="true" /></bpmn:process><bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1s8zutc"><bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_0b1zhsz"><dc:Bounds x="182" y="352" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="159" y="395" width="82" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_0coyc5f_di" bpmnElement="Activity__7ao8ulm"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_0vgx5je_di" bpmnElement="Activity__jy63n9z"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Gateway_12c8cep_di" bpmnElement="Activity__md177lq" isMarkerVisible="true"><dc:Bounds x="50" y="60" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="34" y="117" width="85" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity__57hu482_di" bpmnElement="Activity__57hu482"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_17vsjpa_di" bpmnElement="Activity__kv2b8cd"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity__ebutdlx_di" bpmnElement="Activity__ebutdlx"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_017hsqc_di" bpmnElement="Activity__tbiqcgu"><dc:Bounds x="50" y="60" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="28" y="103" width="90" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity__c737oxi_di" bpmnElement="Activity__c737oxi"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_1xmrha2_di" bpmnElement="Activity__hb589f3"><dc:Bounds x="50" y="60" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="47" y="103" width="53" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity__mm99xbj_di" bpmnElement="Activity__mm99xbj"><dc:Bounds x="82" y="82" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="75" y="125" width="51" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Gateway__3joix88_di" bpmnElement="Gateway__3joix88" isMarkerVisible="true"><dc:Bounds x="75" y="75" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="62" y="132" width="85" height="40" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNEdge id="Flow__lqj4e1q_di" bpmnElement="Flow__lqj4e1q"><di:waypoint x="182" y="370" /><di:waypoint x="166" y="370" /><di:waypoint x="166" y="100" /><di:waypoint x="150" y="100" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__qhqypbu_di" bpmnElement="Flow__qhqypbu"><di:waypoint x="100" y="60" /><di:waypoint x="100" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="100" y="60" /><bpmndi:BPMNLabel><dc:Bounds x="19" y="22" width="42" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__g2dfmm5_di" bpmnElement="Flow__g2dfmm5"><di:waypoint x="100" y="60" /><di:waypoint x="100" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="100" y="60" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__pvkegu2_di" bpmnElement="Flow__pvkegu2"><di:waypoint x="75" y="60" /><di:waypoint x="75" y="40" /><di:waypoint x="95" y="40" /><di:waypoint x="75" y="40" /><di:waypoint x="75" y="60" /><bpmndi:BPMNLabel><dc:Bounds x="56" y="22" width="64" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__q9knbpb_di" bpmnElement="Flow__q9knbpb"><di:waypoint x="75" y="60" /><di:waypoint x="75" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="0" y="0" /><bpmndi:BPMNLabel><dc:Bounds x="-29" y="22" width="87" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__ocsyn4f_di" bpmnElement="Flow__ocsyn4f"><di:waypoint x="75" y="60" /><di:waypoint x="75" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="75" y="60" /><bpmndi:BPMNLabel><dc:Bounds x="-18" y="22" width="87" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__0v4baj3_di" bpmnElement="Flow__0v4baj3"><di:waypoint x="100" y="60" /><di:waypoint x="100" y="40" /><di:waypoint x="75" y="40" /><di:waypoint x="75" y="60" /><bpmndi:BPMNLabel><dc:Bounds x="74" y="22" width="30" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__szxp4t6_di" bpmnElement="Flow__szxp4t6"><di:waypoint x="100" y="60" /><di:waypoint x="100" y="40" /><di:waypoint x="68" y="40" /><di:waypoint x="68" y="60" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__z9sgzu6_di" bpmnElement="Flow__z9sgzu6"><di:waypoint x="100" y="60" /><di:waypoint x="100" y="40" /><di:waypoint x="120" y="40" /><di:waypoint x="100" y="40" /><di:waypoint x="100" y="60" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__hc5hhja_di" bpmnElement="Flow__hc5hhja"><di:waypoint x="100" y="60" /><di:waypoint x="100" y="40" /><di:waypoint x="68" y="40" /><di:waypoint x="68" y="60" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__wz290pt_di" bpmnElement="Flow__wz290pt"><di:waypoint x="100" y="82" /><di:waypoint x="100" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="100" y="75" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__3d4ngu8_di" bpmnElement="Flow__3d4ngu8"><di:waypoint x="100" y="75" /><di:waypoint x="100" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="100" y="60" /><bpmndi:BPMNLabel><dc:Bounds x="32" y="22" width="41" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow__1d0u9zt_di" bpmnElement="Flow__1d0u9zt"><di:waypoint x="100" y="75" /><di:waypoint x="100" y="40" /><di:waypoint x="0" y="40" /><di:waypoint x="100" y="60" /><bpmndi:BPMNLabel><dc:Bounds x="74" y="49" width="32" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></bpmn:definitions>