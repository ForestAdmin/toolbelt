<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:forest="https://app.forestadmin.com" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_0hdve55" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.6.1"><bpmn:process id="Process_1s8zutc" isExecutable="false"><bpmn:startEvent id="StartEvent_0b1zhsz" name="Start of workflow"><bpmn:outgoing>Flow__quzktdi</bpmn:outgoing></bpmn:startEvent><bpmn:SequenceFlow id="Flow__quzktdi" sourceRef="StartEvent_0b1zhsz" targetRef="Activity__ufq2a5e" /><bpmn:ServiceTask id="Activity__ufq2a5e" name="Get Email &#38; Name" forest:description="Retrieve the customer&#39;s email, first name, and last name." forest:alternative="get-data" forest:automaticCompletion="true"><bpmn:incoming>Flow__quzktdi</bpmn:incoming><bpmn:outgoing>Flow__5h1pqxu</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__5h1pqxu" sourceRef="Activity__ufq2a5e" targetRef="Gateway__9aax433" /><bpmn:endEvent id="Activity__r8yoq51" name="End"><bpmn:incoming>Flow__qvw9geq</bpmn:incoming></bpmn:endEvent><bpmn:ServiceTask id="Activity__rnct6kw" name="Request missing documents" forest:description="Notify the customer (using their email as the requester) that some of their documents are missing, to complete their onboarding (fill in the blanks where possible):&#10;&#10;&#34;Dear [customer name],&#10;&#10;We are missing a few documents in order to complete your onboarding:&#10;&#10;[list of missing documents]&#10;&#10;Please add them to your personal space in our app, or send them in response to this email.&#10;&#10;Thanks!&#10;The Forest Team&#34;&#10;&#10;Use the &#34;billing@d3v-forestadminsupport.zendesk.com&#34; email address as the recipient.&#10;Set the Priority to &#34;Low&#34;.&#10;Add &#34;RFI&#34; as a Tag.&#10;Set the Status to &#34;Closed&#34;." forest:alternative="mcp-server" forest:mcpServerId="153" forest:automaticExecution="true" forest:automaticCompletion="true"><bpmn:incoming>Flow__bk7vrw4</bpmn:incoming><bpmn:outgoing>Flow__qvw9geq</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__qvw9geq" sourceRef="Activity__rnct6kw" targetRef="Activity__r8yoq51" /><bpmn:ExclusiveGateway id="Gateway__9aax433" name="Reason for contact" forest:description="What&#39;s the reason for contacting the customer?" forest:aiDecision="true"><bpmn:incoming>Flow__5h1pqxu</bpmn:incoming><bpmn:outgoing>Flow__f5xfdiv</bpmn:outgoing><bpmn:outgoing>Flow__a7gw6h6</bpmn:outgoing><bpmn:outgoing>Flow__023r2pv</bpmn:outgoing></bpmn:ExclusiveGateway><bpmn:SequenceFlow id="Flow__f5xfdiv" name="Missing documents" sourceRef="Gateway__9aax433" targetRef="Activity__qhw2mil" forest:buttonColor="yellow" /><bpmn:SequenceFlow id="Flow__a7gw6h6" name="Refund request approved" sourceRef="Gateway__9aax433" targetRef="Activity__w9nv9o1" /><bpmn:SequenceFlow id="Flow__023r2pv" name="Refind request declined" sourceRef="Gateway__9aax433" targetRef="Activity__h3xwwva" forest:buttonColor="red" /><bpmn:ServiceTask id="Activity__w9nv9o1" name="Refund request approved" forest:description="Notify the customer that their refund request was approved (fill in the blanks where possible):&#10;&#10;Dear [customer name],&#10;&#10;We are pleased to let you know that your refund request has been accepted:&#10;&#10;[details regarding refund request]&#10;&#10;Please allow up to 5 days for the funds to be back on your account.&#10;&#10;Thanks!&#10;The Forest Team" forest:alternative="mcp-server" forest:mcpServerId="153" forest:automaticExecution="true" forest:automaticCompletion="true"><bpmn:incoming>Flow__a7gw6h6</bpmn:incoming><bpmn:outgoing>Flow__rvvyma5</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__rvvyma5" sourceRef="Activity__w9nv9o1" targetRef="Activity__uh8cfia" /><bpmn:ServiceTask id="Activity__h3xwwva" name="Refund request declined" forest:description="Notify the customer that their refund request was declined (fill in the blanks where possible):&#10;&#10;Dear [customer name],&#10;&#10;After careful review, we regret to let you know that your refund request has been declined:&#10;&#10;[details regarding refund request]&#10;[reason for refusal]&#10;&#10;Feel free to respond to this email if you believe there was an error on our part, otherwise you can consider this case closed.&#10;&#10;Thanks!&#10;The Forest Team" forest:alternative="mcp-server" forest:mcpServerId="153" forest:automaticExecution="true" forest:automaticCompletion="true"><bpmn:incoming>Flow__023r2pv</bpmn:incoming><bpmn:outgoing>Flow__dtgj5b6</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__dtgj5b6" sourceRef="Activity__h3xwwva" targetRef="Activity__9wkehs5" /><bpmn:endEvent id="Activity__uh8cfia" name="End"><bpmn:incoming>Flow__rvvyma5</bpmn:incoming></bpmn:endEvent><bpmn:endEvent id="Activity__9wkehs5" name="End"><bpmn:incoming>Flow__dtgj5b6</bpmn:incoming></bpmn:endEvent><bpmn:UserTask id="Activity__qhw2mil" name="Which documents?" forest:description="Please list all the missing documents here." forest:completionType="user-input" forest:inputType="free-text"><bpmn:incoming>Flow__f5xfdiv</bpmn:incoming><bpmn:outgoing>Flow__bk7vrw4</bpmn:outgoing></bpmn:UserTask><bpmn:SequenceFlow id="Flow__bk7vrw4" sourceRef="Activity__qhw2mil" targetRef="Activity__rnct6kw" /></bpmn:process><bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1s8zutc"><bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_0b1zhsz"><dc:Bounds x="182" y="352" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="159" y="395" width="82" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_0orn7ek_di" bpmnElement="Activity__ufq2a5e"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPM