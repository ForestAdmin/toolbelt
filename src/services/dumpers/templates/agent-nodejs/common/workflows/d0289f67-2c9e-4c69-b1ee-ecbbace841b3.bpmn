Activity__xz6dmcl" targetRef="Activity__lopka1l" /><bpmn:ExclusiveGateway id="Activity__vv5ijd8" name="Clear or Escalate?" forest:description="Based on the transaction history, and screening results regarding the customer, would you recommend clearing this alert, or escalating it to a senior compliance officer?" forest:aiDecision="true"><bpmn:incoming>Flow__n4zvzbn</bpmn:incoming><bpmn:outgoing>Flow__lsnkn7w</bpmn:outgoing><bpmn:outgoing>Flow__aakv4yc</bpmn:outgoing></bpmn:ExclusiveGateway><bpmn:SequenceFlow id="Flow__aakv4yc" name="All good, clear" sourceRef="Activity__vv5ijd8" targetRef="Activity__3rqh8bm" /><bpmn:SequenceFlow id="Flow__lsnkn7w" name="Suspicious, escalate" sourceRef="Activity__vv5ijd8" targetRef="Activity__q15qdm0" forest:buttonColor="red" /><bpmn:ServiceTask id="Activity__3rqh8bm" name="Clear alert" forest:description="Trigger the Clear Alert action, as a false positive" forest:alternative="trigger-action" forest:automaticExecution="true" forest:automaticCompletion="true"><bpmn:incoming>Flow__aakv4yc</bpmn:incoming><bpmn:outgoing>Flow__zt4w1ai</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__zt4w1ai" sourceRef="Activity__3rqh8bm" targetRef="Activity__j209e41" /><bpmn:endEvent id="Activity__j209e41" name="Alert cleared"><bpmn:incoming>Flow__zt4w1ai</bpmn:incoming></bpmn:endEvent><bpmn:ServiceTask id="Activity__q15qdm0" name="Create SAR" forest:description="Trigger the Create SAR action, and fill out the report with the information gathered during the investigation." forest:alternative="trigger-action" forest:automaticCompletion="true"><bpmn:incoming>Flow__lsnkn7w</bpmn:incoming><bpmn:outgoing>Flow__ik7ncjb</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__ik7ncjb" sourceRef="Activity__q15qdm0" targetRef="Activity__6yaq353" /><bpmn:IntermediateThrowEvent id="Activity__6yaq353" name="Escalation" forest:inboxId="48dc1277-8434-40a6-b495-9b5d69ed6e7c"><bpmn:incoming>Flow__ik7ncjb</bpmn:incoming><bpmn:outgoing>Flow__wdmspqe</b