174" forest:automaticExecution="true" forest:automaticCompletion="false"><bpmn:incoming>Flow__9k15d0t</bpmn:incoming><bpmn:outgoing>Flow__r62um7y</bpmn:outgoing></bpmn:ServiceTask><bpmn:SequenceFlow id="Flow__r62um7y" sourceRef="Activity__lopka1l" targetRef="Activity__89w5ifc" /></bpmn:process><bpmndi:BPMNDiagram id="BPMNDiagram_1"><bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1s8zutc"><bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_0b1zhsz"><dc:Bounds x="182" y="352" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="159" y="395" width="82" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_01nk1ey_di" bpmnElement="Activity__h5nee4i"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_11it7eo_di" bpmnElement="Activity__iy6ihfh"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_1qktc44_di" bpmnElement="Activity__xz6dmcl"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Gateway_1m09ib9_di" bpmnElement="Activity__vv5ijd8" isMarkerVisible="true"><dc:Bounds x="50" y="60" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="54" y="117" width="49" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_0twb28e_di" bpmnElement="Activity__3rqh8bm"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_0eb2lvf_di" bpmnElement="Activity__j209e41"><dc:Bounds x="50" y="60" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="38" y="103" width="62" height="14" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="Activity_15jkk14_di" bpmnElement="Activity__q15qdm0"><dc:Bounds x="50" y="60" width="100" height="80" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape><bpmndi:BPMNShape id="Event_1sy0b4c_di" bpmnElement="